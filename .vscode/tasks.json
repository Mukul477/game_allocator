{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build allocator project",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-Wall",
                "-Wextra",
                "-g3",
                "src/custom_sim.c",
                "src/allocator.c",
                "src/slab.c",
                "src/memory_pool.c",
                "-o",
                "src/output/custom_sim.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}